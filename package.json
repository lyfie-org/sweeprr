{
  "name": "sweeprr",
  "private": true,
  "packageManager": "pnpm@11.5.1",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "concurrently -k -n api,web -c blue,green \"pnpm run dev:api\" \"pnpm run dev:web\"",
    "dev:api": "dotnet watch --project Sweeprr.API run",
    "dev:web": "pnpm --filter sweeprr-client dev",
    "build": "pnpm --filter sweeprr-client build"
  },
  "devDependencies": {
    "concurrently": "^9"
  }
}
